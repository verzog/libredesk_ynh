#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP SERVICE BEFORE UPGRADE
#=================================================
ynh_script_progression "Stopping LibreDesk for upgrade..."

ynh_systemctl --service="$app" --action="stop"

#=================================================
# DOWNLOAD AND INSTALL NEW BINARY
#=================================================
ynh_script_progression "Downloading new LibreDesk binary..."

if [ "$(uname -m)" = "aarch64" ]; then
    ynh_setup_source --dest_dir="$install_dir" --source_id="main_arm64" --full_replace
else
    ynh_setup_source --dest_dir="$install_dir" --full_replace
fi

chmod +x "$install_dir/libredesk"

# Restore the config file (full_replace would have removed it)
ynh_config_add --template="config.toml" --destination="$install_dir/config.toml"
chmod 600 "$install_dir/config.toml"
chown "$app:$app" "$install_dir/config.toml"

#=================================================
# RUN DATABASE MIGRATIONS
#=================================================
ynh_script_progression "Running database migrations..."

pushd "$install_dir"
    ynh_exec_as_app ./libredesk --upgrade --yes --config config.toml
popd

#=================================================
# UPDATE NGINX, SYSTEMD, AND LOGROTATE CONFIGURATION
#=================================================
ynh_script_progression "Updating configuration files..."

mkdir -p /var/log/$app
chown $app:adm /var/log/$app
chmod 750 /var/log/$app

ynh_config_add_systemd
ynh_config_add_logrotate
ynh_config_add_nginx

#=================================================
# REREGISTER SERVICE
#=================================================
yunohost service add "$app" --description="LibreDesk customer support desk" --log="/var/log/$app/$app.log"

#=================================================
# START SERVICE
#=================================================
ynh_script_progression "Restarting LibreDesk..."

ynh_systemctl --service="$app" --action="start"

#=================================================
# END OF SCRIPT
#=================================================
ynh_script_progression "Upgrade of LibreDesk completed!"
